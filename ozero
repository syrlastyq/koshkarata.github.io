  .msg.bot { align-self: flex-start; }
  .msg.user { align-self: flex-end; }

  .msg-bubble {
    padding: 0.7rem 1rem;
    font-size: 0.82rem;
    line-height: 1.6;
    border-radius: 2px;
  }
  .msg.bot .msg-bubble {
    background: var(--card);
    color: var(--white);
    border-left: 2px solid var(--red);
  }
  .msg.user .msg-bubble {
    background: rgba(230,57,70,0.18);
    color: var(--white);
    border-right: 2px solid var(--amber);
  }
  .msg-time {
    font-size: 0.6rem;
    color: var(--muted);
    margin-top: 0.3rem;
    letter-spacing: 1px;
  }
  .msg.user .msg-time { text-align: right; }

  /* Typing indicator */
  .typing-indicator {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0.8rem 1rem;
    background: var(--card);
    border-left: 2px solid var(--red);
    width: fit-content;
    border-radius: 2px;
  }
  .typing-indicator span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--red);
    animation: typing-dot 1.2s ease-in-out infinite;
  }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing-dot {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30%            { transform: translateY(-5px); opacity: 1; }
  }

  /* Quick suggestions */
  .chat-suggestions {
    padding: 0.5rem 1rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .suggestion-btn {
    background: rgba(230,57,70,0.1);
    border: 1px solid rgba(230,57,70,0.3);
    color: var(--muted);
    font-size: 0.68rem;
    padding: 0.3rem 0.7rem;
    cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    transition: background 0.2s, color 0.2s;
    border-radius: 2px;
  }
  .suggestion-btn:hover { background: rgba(230,57,70,0.2); color: var(--white); }

  /* Input area */
  .chat-input-area {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 0.8rem;
    display: flex;
    gap: 0.6rem;
    flex-shrink: 0;
    background: #080f18;
  }
  #chat-input {
    flex: 1;
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    padding: 0.6rem 0.9rem;
    outline: none;
    border-radius: 2px;
    transition: border-color 0.2s;
  }
  #chat-input::placeholder { color: var(--muted); }
  #chat-input:focus { border-color: rgba(230,57,70,0.5); }

  #chat-send {
    background: var(--red);
    border: none;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s;
    border-radius: 2px;
  }
  #chat-send:hover { background: #c0222f; }
  #chat-send:disabled { background: #3a1a1e; cursor: not-allowed; }

  @media (max-width: 480px) {
    #chat-window { width: calc(100vw - 2rem); left: 1rem; right: 1rem; }
    #chat-toggle { left: 1rem; bottom: 1rem; }
  }
</style>

<!-- ══════════════════════════════════════════
     CHATBOT HTML
════════════════════════════════════════════ -->
<button id="chat-toggle" aria-label="Открыть чат">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
</button>

<div id="chat-window" role="dialog" aria-label="Чат-бот Кошкар-Ата">
  <div class="chat-header">
    <div class="chat-avatar">☢</div>
    <div class="chat-header-info">
      <div class="chat-header-name">КОШКАР-АТА БОТ</div>
      <div class="chat-header-sub">Эксперт по экологии · Онлайн</div>
    </div>
    <button class="chat-close" id="chat-close-btn" aria-label="Закрыть">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="chat-messages" id="chat-messages"></div>

  <div class="chat-suggestions" id="chat-suggestions">
    <button class="suggestion-btn">Что такое Кошкар-Ата?</button>
    <button class="suggestion-btn">Угроза Каспию</button>
    <button class="suggestion-btn">Почему не решают?</button>
    <button class="suggestion-btn">Состав отходов</button>
  </div>

  <div class="chat-input-area">
    <input id="chat-input" type="text" placeholder="Задайте вопрос..." maxlength="500" autocomplete="off">
    <button id="chat-send" aria-label="Отправить">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<!-- ══════════════════════════════════════════
     CHATBOT SCRIPT — рабочий, через Anthropic API
════════════════════════════════════════════ -->
<script>
(function() {
  const toggle    = document.getElementById('chat-toggle');
  const win       = document.getElementById('chat-window');
  const closeBtn  = document.getElementById('chat-close-btn');
  const msgArea   = document.getElementById('chat-messages');
  const inp       = document.getElementById('chat-input');
  const sendBtn   = document.getElementById('chat-send');
  const suggestEl = document.getElementById('chat-suggestions');

  let isOpen = false;
  let busy   = false;
  const history = [];

  const SYSTEM = `Ты — узкоспециализированный эксперт-бот по теме хвостохранилища Кошкар-Ата.

ОТВЕЧАЙ ТОЛЬКО на вопросы об этих темах:
- Хвостохранилище Кошкар-Ата: история, расположение, масштаб угрозы
- Состав отходов: уран, стронций, кобальт, никель, свинец, фосфогипсы
- Угрозы Каспийскому морю от Кошкар-Ата
- Токсичная пыль и её влияние на жителей Актау (176 000 человек)
- Заражение грунтовых вод, месторождение Куюлус
- Рекультивация: ход работ, стоимость (17 млрд тенге), проблемы
- Советский период, история создания ХГМЗ
- Радиоактивное загрязнение Мангистауской области
- Инцидент февраль 2025 — красная вода Каспия у Актау

ФАКТЫ для ответов:
105 млн тонн — общий объём отходов
52 млн тонн — радиоактивные
8 км — до Каспийского моря
5 км — до Актау (176 000 жителей)
13 км² — обезвоженная зона с высокой радиацией
20+ лет — длится рекультивация
17 млрд тенге — стоимость рекультивации
Уровень озера ВЫШЕ уровня Каспия — прорыв дамбы = катастрофа

ЕСЛИ ВОПРОС НЕ ПО ТЕМЕ — отвечай строго этой фразой:
"🚫 Это не в моей компетенции. Я — эксперт только по хвостохранилищу Кошкар-Ата. Спросите меня о радиоактивных отходах, угрозе Каспию или экологии Мангистауской области."

Стиль: кратко 2-4 предложения, конкретные факты, только русский язык.`;

  function openChat() {
    isOpen = true;
    win.classList.add('open');
    toggle.classList.add('open');
    if (msgArea.children.length === 0) {
      addBot('Здравствуйте! Я эксперт-бот по теме хвостохранилища Кошкар-Ата ☢

Задайте любой вопрос об этой экологической катастрофе — я готов ответить.');
    }
    setTimeout(() => inp.focus(), 300);
  }
  function closeChat() {
    isOpen = false;
    win.classList.remove('open');
    toggle.classList.remove('open');
  }

  toggle.addEventListener('click', () => isOpen ? closeChat() : openChat());
  closeBtn.addEventListener('click', closeChat);

  suggestEl.querySelectorAll('.suggestion-btn').forEach(btn => {
    btn.addEventListener('click', () => { if (!busy) doSend(btn.textContent); });
  });

  inp.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); trySubmit(); }
  });
  sendBtn.addEventListener('click', trySubmit);

  function trySubmit() {
    const t = inp.value.trim();
    if (t && !busy) { inp.value = ''; doSend(t); }
  }

  async function doSend(text) {
    addUser(text);
    history.push({ role: 'user', content: text });
    suggestEl.style.display = 'none';
    busy = true;
    sendBtn.disabled = true;

    const typEl = addTyping();

    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 800,
          system: SYSTEM,
          messages: history
        })
      });
      const data = await res.json();
      const reply = (data.content || []).map(b => b.text || '').join('') || 'Ошибка. Попробуйте ещё раз.';
      remove(typEl);
      addBot(reply);
      history.push({ role: 'assistant', content: reply });
    } catch(e) {
      remove(typEl);
      addBot('Нет соединения с сервером. Попробуйте позже.');
    }

    busy = false;
    sendBtn.disabled = false;
    inp.focus();
  }

  function addUser(text) {
    const d = make('div', 'msg user');
    d.innerHTML = `<div class="msg-bubble">${esc(text)}</div><div class="msg-time">${ts()}</div>`;
    msgArea.appendChild(d); scroll();
  }
  function addBot(text) {
    const d = make('div', 'msg bot');
    d.innerHTML = `<div class="msg-bubble">${esc(text)}</div><div class="msg-time">☢ бот · ${ts()}</div>`;
    msgArea.appendChild(d); scroll();
  }
  function addTyping() {
    const d = make('div', 'msg bot');
    d.innerHTML = '<div class="typing-indicator"><span></span><span></span><span></span></div>';
    msgArea.appendChild(d); scroll(); return d;
  }
  function make(tag, cls) { const e = document.createElement(tag); e.className = cls; return e; }
  function remove(el) { if (el && el.parentNode) el.parentNode.removeChild(el); }
  function scroll() { setTimeout(() => msgArea.scrollTop = msgArea.scrollHeight, 50); }
  function ts() { return new Date().toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'}); }
  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
  }
})();
</script>
</body>
</html>
